# ⚙️ Variables de Entorno — Made Util v6.0

# Puerto del servidor
PORT=3001

# ==================== WHATSAPP ====================

# OPCIÓN 1: ManyChat (Recomendado - No necesita variables aquí)
WHATSAPP_PLATFORM=manychat

# OPCIÓN 2: Meta Official API
WHATSAPP_API_TOKEN=your_meta_graph_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=made_util_verify_token_123

# OPCIÓN 3: Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+1234567890

# ==================== BASE DE DATOS ====================

DB_PATH=./db/database.json
DB_BACKUP=./db/backup.json

# ==================== EMAIL (Opcional) ====================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ==================== SEGURIDAD ====================

ADMIN_PASSWORD=123
JWT_SECRET=your_jwt_secret_key_here
API_KEY=made_util_api_key_123

# ==================== LOGS ====================

LOG_LEVEL=info
DEBUG=false

# ==================== PRODUCCIÓN ====================

NODE_ENV=development
# Change to NODE_ENV=production for live server
